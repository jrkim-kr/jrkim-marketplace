{
  "skill_name": "architect-advisor",
  "evals": [
    {
      "id": 1,
      "prompt": "우리 쇼핑몰에 결제 시스템을 새로 만들어야 해. 카카오페이, 토스페이 연동하고 환불 처리도 필요해. 이 모듈 설계 도와줘.",
      "expected_output": "decompose → decision → adr → audit → portfolio 순서대로 실행: Mermaid 토폴로지, MVP vs 견고한 아키텍처 비교 테이블, ADR 파일 생성, Integration Risk 포함 리스크 감사, portfolio 회고(Keep/Problem/Try/Revisit/Knowledge Gap). 비전공자 톤(비유 먼저, 괄호 안 용어/원어 — 정의).",
      "files": [],
      "assertions": [
        {"name": "has_all_steps", "type": "contains_all", "values": ["decompose", "decision", "adr", "audit", "portfolio"], "description": "5개 step (decompose~portfolio) 워크플로우 헤딩이 모두 존재"},
        {"name": "has_mermaid_diagram", "type": "contains", "value": "```mermaid", "description": "Mermaid 다이어그램 포함"},
        {"name": "has_comparison_table", "type": "regex", "pattern": "방안\\s*(A|B).*MVP|MVP.*방안\\s*(A|B)", "description": "MVP vs 견고한 아키텍처 비교 테이블"},
        {"name": "has_risk_scenarios", "type": "min_count", "pattern": "시나리오|리스크|장애|실패|재전송", "min": 3, "description": "리스크 시나리오 3개 이상"},
        {"name": "has_adr_generation", "type": "regex", "pattern": "/adr/|0001-.*\\.md", "description": "ADR 파일 경로/파일명 생성"},
        {"name": "has_integration_risk_coverage", "type": "contains_any", "values": ["Integration", "통합", "API 계약", "이벤트 순서", "공유 리소스"], "description": "audit Integration Risk 도메인 다룸"},
        {"name": "has_retrospective", "type": "contains_all", "values": ["Keep", "Problem", "Try"], "description": "portfolio 회고 (Keep/Problem/Try)"},
        {"name": "tone_has_analogy", "type": "regex", "pattern": ".+\\((.+?/.+?\\s*—.+?)\\)", "description": "비유 (용어/원어 — 정의) 톤"},
        {"name": "has_trilingual_terms", "type": "regex", "pattern": "[가-힣]+.*[\\u4e00-\\u9fff]+.*[A-Za-z]+|[가-힣]+.*[A-Za-z]+.*\\/", "description": "한/중/영 전문용어 병기"},
        {"name": "has_star_case", "type": "contains_any", "values": ["Situation", "Challenge", "Action", "Result", "배경", "도전", "행동", "성과", "STAR"], "description": "STAR 케이스 스터디 포함"},
        {"name": "has_bilingual_interview", "type": "contains_all", "values": ["한국어", "中文"], "description": "중한 이중언어 면접 요약"},
        {"name": "output_in_korean", "type": "primary_language", "language": "ko", "description": "메인 출력이 한국어"},
        {"name": "has_idempotency", "type": "contains_any", "values": ["멱등", "Idempoten", "幂等"], "description": "멱등성 개념 다룸 (결제 필수)"},
        {"name": "no_code_before_decision", "type": "custom", "description": "decision step 확정 전 구체적 비즈니스 코드 없음"}
      ]
    },
